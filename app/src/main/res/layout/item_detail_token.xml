<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorSurfaceVariant">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Icono identificativo dinámico -->
        <TextView
            android:id="@+id/tvTokenIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎲"
            android:textSize="18sp"
            android:layout_marginEnd="12dp"/>

        <!-- Texto Principal (Nombre de regla, equipo o número de turno) -->
        <TextView
            android:id="@+id/tvTokenName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nombre del componente"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"/>

        <!-- Indicador de Fuerza - Estilo marcador de puntuación -->
        <TextView
            android:id="@+id/tvTokenStat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fuerza 0"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:background="@drawable/bg_board_game_token"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:layout_marginEnd="8dp"/>

        <!-- Botón de eliminar (Visible sólo si corresponde) -->
        <TextView
            android:id="@+id/btnDeleteToken"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❌"
            android:textSize="14sp"
            android:padding="4dp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>