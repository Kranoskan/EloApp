<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:windowBackground"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="160dp"
            android:layout_height="160dp"
            app:cardCornerRadius="80dp"
            app:cardElevation="10dp"
            app:strokeWidth="3dp"
            app:strokeColor="?attr/colorSecondary"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/ivPlayerDetail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                tools:src="@tools:sample/avatars"
                android:background="?attr/colorSecondaryContainer"/>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvPlayerNameDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            tools:text="Nombre del Jugador"
            android:textAlignment="center"/>

        <TextView
            android:id="@+id/tvGlobalStrength"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:textSize="18sp"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            tools:text="Fuerza Global Media: 1200"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditPlayer"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EDITAR JUGADOR"
            android:layout_marginBottom="24dp"
            app:icon="@android:drawable/ic_menu_edit"
            app:cornerRadius="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Estadísticas por Juego"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="16dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPlayerGameStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:spanCount="2"
            tools:listitem="@layout/item_player_game_stats"/>

        <Button
            android:id="@+id/btnDeletePlayer"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ELIMINAR JUGADOR"
            android:textColor="@color/meeple_red_light"
            android:layout_marginTop="24dp"/>

    </LinearLayout>
</ScrollView>
