<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nueva Partida"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSelectGame"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Seleccionar Juego"
            android:layout_marginBottom="8dp">

            <AutoCompleteTextView
                android:id="@+id/actvSelectGame"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tvExpansionsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Expansiones utilizadas"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            android:visibility="gone"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cgExpansions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnSelectExpansions"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Seleccionar Expansiones"
            android:layout_marginBottom="16dp"
            android:visibility="gone"/>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swIsTeamGame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Partida por equipos"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvParticipantsHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Participantes"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/llParticipantsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <Button
            android:id="@+id/btnAddParticipant"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Añadir Participante"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/btnSaveMatch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Guardar Partida"
            android:layout_marginTop="24dp"/>

    </LinearLayout>
</ScrollView>
