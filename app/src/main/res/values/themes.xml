<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MeepleForce" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Colores Principales -->
        <item name="colorPrimary">@color/meeple_blue_light</item>
        <item name="colorSecondary">@color/meeple_green_light</item>
        <item name="android:windowBackground">@color/wood_light</item>

        <!-- Superficies de cartas y componentes -->
        <item name="colorSurface">@color/card_bg_light</item>
        <item name="colorOnSurface">@color/text_main_light</item>

        <!-- Bordes y personalización de Material Cards por defecto -->
        <item name="cardViewStyle">@style/Widget.MeepleForce.CardView</item>
    </style>

    <!-- Estilo propio para que las cartas parezcan cartas de juego reales -->
    <style name="Widget.MeepleForce.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/card_bg_light</item>
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">16dp</item> <!-- Esquinas muy redondeadas tipo carta -->
    </style>
</resources>